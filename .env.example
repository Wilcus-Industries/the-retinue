# Retinue environment contract — mirrors retinue/config.py Settings.
# Copy to .env and fill the required values:  cp .env.example .env
# .env is gitignored — NEVER commit it.
#
# Required values are uncommented and blank. Values that docker-compose sets for you
# are commented out (uncomment only to override the compose topology).

# Required — GitHub App webhook HMAC secret. Keep this line comment-free: compose
# treats everything after the value as part of it (a trailing "# comment" silently
# corrupts the secret).
WEBHOOK_SECRET=
# Required — bearer token every /api/* request must present as
# `Authorization: Bearer <token>`.
API_SERVICE_TOKEN=
# REDIS_URL=redis://localhost:6379    # compose overrides to redis://redis:6379
AUTH_MODE=api_key                     # api_key ($) | subscription (tokens)
WEEKLY_BUDGET=0                       # set a real cap before going live
BUDGET_DAILY_CAP_FRACTION=0.12
# DEDUPE_DB_PATH / BUDGET_DB_PATH     # compose points these at /data
# JOB_TIMEOUT_SECONDS=1800            # arq job timeout; must outlast a full build
# IMPLEMENT_MAX_TURNS=80              # cap on the implementer's agent loop
# HEIMDALL_BOT_LOGIN=heimdall[bot]    # reviewer bot login the loopback listens for

# --- pipeline adapters (required once the worker drives the real pipeline) ---
# GitHub App auth mints the per-repo tokens the gh adapters use; the private key is read
# from a mounted file path, never inlined.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/app.pem

# Anthropic auth — BOTH carried, the active AUTH_MODE picks one:
#   AUTH_MODE=api_key      -> ANTHROPIC_API_KEY ($, x-api-key)
#   AUTH_MODE=subscription -> CLAUDE_CODE_OAUTH_TOKEN (tokens, Bearer + oauth beta)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Push channel — configure EITHER ntfy OR Pushover (else the push is a logged no-op).
NTFY_TOPIC=
# NTFY_TOKEN=                          (only for a protected ntfy topic)
# PUSHOVER_TOKEN= ; PUSHOVER_USER=     (Pushover backend instead of ntfy)

# --- edge / tunnel (Caddy profile only) ---
# DOMAIN=        (edge/Caddy profile only)
# CLOUDFLARE_TUNNEL_TOKEN=  (only if you switch to a named tunnel for a stable URL)
